---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";
---

<BaseLayout title="運営者情報" description="当サイトの運営者情報です。">
  <section class="section wrap" style="max-width:760px">
    <p class="eyebrow">ABOUT</p>
    <h1>運営者情報</h1>
    <table class="info">
      <tbody>
        <tr><th>サイト名</th><td>{site.name}</td></tr>
        <tr><th>運営者</th><td>{site.operator.name}</td></tr>
        <tr><th>対応エリア</th><td>{site.area}（{site.regions.map((r) => r.name).join("／")}）</td></tr>
        <tr><th>連絡先</th><td><a href={site.contactForm} target="_blank" rel="noopener noreferrer">お問い合わせフォーム</a></td></tr>
      </tbody>
    </table>
    <p class="muted" style="margin-top:24px">
      当サイトは情報提供を目的とし、掲載事業者のサービスを保証するものではありません。
      広告の扱いは<a href="/disclosure/">広告・PR表記ポリシー</a>をご覧ください。
    </p>
  </section>
</BaseLayout>

<style>
  .info { border-collapse: collapse; width: 100%; }
  .info th, .info td { text-align: left; padding: 12px 14px; border-bottom: 1px solid var(--line); vertical-align: top; }
  .info th { width: 30%; color: var(--ink-soft); font-weight: 700; white-space: nowrap; }
</style>
