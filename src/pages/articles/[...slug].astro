---
import { type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import { site } from "../../config/site";
import { getPublishedArticles } from "../../utils/posts";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"articles">;
}
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

const pageUrl = new URL(`/sougi/articles/${entry.slug}/`, site.url).href;

// 関連記事：同じカテゴリを優先し、足りなければ他カテゴリで補って最大4件。
const publishedExceptThis = (await getPublishedArticles()).filter(
  (a) => a.slug !== entry.slug,
);
const related = [
  ...publishedExceptThis.filter((a) => a.data.category === d.category),
  ...publishedExceptThis.filter((a) => a.data.category !== d.category),
].slice(0, 4);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
    url: pageUrl,
    headline: d.title,
    description: d.description,
    inLanguage: "ja",
    articleSection: d.category,
    datePublished: d.publishedAt,
    dateModified: d.updatedAt ?? d.publishedAt,
    author: { "@type": "Organization", name: d.author, url: site.url },
    publisher: { "@id": `${site.url}#organization` },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "トップ", item: site.url },
      {
        "@type": "ListItem",
        position: 2,
        name: "記事一覧",
        item: new URL("/sougi/articles/", site.url).href,
      },
      { "@type": "ListItem", position: 3, name: d.title, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title={d.title}
  description={d.description}
  ogType="article"
  publishedTime={d.publishedAt}
  modifiedTime={d.updatedAt ?? d.publishedAt}
>
  <article class="section wrap article">
    <nav class="crumbs" aria-label="パンくずリスト">
      <a href="/sougi/">トップ</a>
      <span aria-hidden="true">›</span>
      <a href="/sougi/articles/">記事一覧</a>
      <span aria-hidden="true">›</span>
      <span class="current">{d.category}</span>
    </nav>
    <p class="eyebrow">{d.category}{d.area ? `・${d.area}` : ""}</p>
    <h1>{d.title}</h1>
    <p class="meta muted">
      公開: {d.publishedAt}
      {d.updatedAt && d.updatedAt !== d.publishedAt && <> ／ 更新: {d.updatedAt}</>}
      ／ {d.author}
    </p>

    <div class="prose">
      <Content />
    </div>

    <!-- 記事末の広告枠（有料掲載・PR表記つき） -->
    <AdSlot slot="article-bottom" />

    {related.length > 0 && (
      <aside class="related" aria-label="関連記事">
        <h2>関連記事</h2>
        <ul>
          {related.map((a) => (
            <li>
              <a href={`/sougi/articles/${a.slug}/`}>
                <span class="cat">{a.data.category}</span>
                <span class="ttl">{a.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</BaseLayout>

<style>
  .article { max-width: 760px; }
  .crumbs { font-size: 0.8rem; color: var(--ink-soft); margin-bottom: 14px; }
  .crumbs a { color: var(--ink-soft); text-decoration: none; }
  .crumbs a:hover { color: var(--sei); }
  .crumbs span { margin: 0 6px; }
  .crumbs .current { margin: 0; color: var(--ink); }
  .meta { margin-top: 4px; }
  .prose :global(h2) { border-bottom: 1px solid var(--line); padding-bottom: 0.3em; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--sei);
    margin: 1.6em 0;
    padding: 0.6em 1.2em;
    background: var(--paper-deep);
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .prose :global(ol), .prose :global(ul) { padding-left: 1.4em; }
  .prose :global(li) { margin: 0.4em 0; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.4em 0; }
  .prose :global(em) { color: var(--ink-soft); }

  .related { margin-top: 48px; padding-top: 28px; border-top: 1px solid var(--line); }
  .related h2 { margin: 0 0 16px; font-size: 1.25rem; }
  .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .related li { background: var(--paper-deep); border: 1px solid var(--line); border-radius: var(--radius); }
  .related a { display: block; padding: 16px 18px; text-decoration: none; }
  .related .cat { font-size: 0.72rem; color: var(--sei); font-weight: 700; letter-spacing: 0.08em; }
  .related .ttl { display: block; margin-top: 6px; font-family: var(--font-serif); font-size: 1.02rem; color: var(--ink); line-height: 1.5; }
  .related a:hover .ttl { color: var(--ai); }
</style>
