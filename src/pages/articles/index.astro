---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedArticles } from "../../utils/posts";

const articles = await getPublishedArticles();
---

<BaseLayout title="記事一覧" description="葬儀の費用・形式の選び方、もしもの時の流れ、事前相談など、お葬式に関する解説記事の一覧です。">
  <section class="section wrap">
    <p class="eyebrow">ARTICLES</p>
    <h1>記事一覧</h1>
    <ul class="list">
      {articles.map((a) => (
        <li>
          <a href={`/sougi/articles/${a.slug}/`}>
            <span class="cat">{a.data.category}</span>
            <span class="title">{a.data.title}</span>
            <span class="muted">{a.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .list { list-style: none; padding: 0; margin: 32px 0 0; }
  .list li { border-top: 1px solid var(--line); }
  .list li:last-child { border-bottom: 1px solid var(--line); }
  .list a { display: block; padding: 22px 0; text-decoration: none; }
  .cat { display: inline-block; font-size: 0.75rem; color: var(--sei); font-weight: 700; letter-spacing: 0.08em; }
  .title { display: block; font-family: var(--font-serif); font-size: 1.2rem; color: var(--ink); margin: 4px 0 6px; }
</style>
