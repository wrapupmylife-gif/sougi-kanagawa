{
  // 静的アセットのみのWorker。dist/ 配下（dist/sougi/**）をそのまま配信する。
  // routes によりデプロイ時に kanagawashukatsu.com/sougi* が自動でこのWorkerに割り当たる。
  "name": "sougi-kanagawa",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    { "pattern": "kanagawashukatsu.com/sougi*", "zone_name": "kanagawashukatsu.com" }
  ]
}
